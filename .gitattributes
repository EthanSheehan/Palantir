# Cross-platform line-ending normalization (Mac <-> Windows on exFAT).
# `text=auto` lets git decide, then forces LF in the repo and native on checkout.

* text=auto

# Force LF for shell scripts (must be LF to run in bash/WSL)
*.sh    text eol=lf
*.bash  text eol=lf

# Force CRLF for Windows scripts
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# Source files — repo stores LF
*.py    text eol=lf
*.js    text eol=lf
*.ts    text eol=lf
*.jsx   text eol=lf
*.tsx   text eol=lf
*.html  text eol=lf
*.css   text eol=lf
*.scss  text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.toml  text eol=lf

# Binaries — never normalize
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary
*.docx  binary
*.xlsx  binary
*.pptx  binary
*.zip   binary
*.tar   binary
*.tar.gz binary
*.gz    binary
*.7z    binary
*.exe   binary
*.dll   binary
*.so    binary
*.dylib binary
*.pyc   binary
*.whl   binary
