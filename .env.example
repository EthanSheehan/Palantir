# Grid-Sentinel C2 System — Environment Variables
# Copy this file to .env and fill in actual values.

# Required for LangChain/OpenAI agent features
OPENAI_API_KEY=

# Optional: Anthropic Claude API (for agent layer)
ANTHROPIC_API_KEY=

# Google Gemini API (primary LLM provider)
GEMINI_API_KEY=

# Server configuration
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# Simulation tick rate (Hz)
SIMULATION_HZ=10

# WebSocket backend URL (used by simulator clients)
WS_BACKEND_URL=ws://localhost:8000/ws
